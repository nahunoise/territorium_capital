---
import Layout from '../layouts/Layout.astro';
import PageStyles from '../components/PageStyles.astro';
---

<Layout
  title="Territorium - Resiliencia y rentabilidad territorial"
  canonicalPath="/"
  preloadImages={['/imagenes/fondo-1.webp', '/imagenes/fondo-2.webp', '/imagenes/fondo-3.webp']}
>
  <PageStyles />

  <header class="hero home-hero" id="hero-carousel">
    <div class="hero__content">
      <span class="hero__eyebrow">Territorium Capital</span>
      <h1 class="hero__title fade-in" id="carousel-title">
        Territorios con valor natural para inversores y propietarios
      </h1>
      <p class="hero__subtitle fade-in" id="carousel-subtitle">
        Convertimos territorio, biodiversidad y restauración en resiliencia,
        rentabilidad y legado.
      </p>
      <div class="hero__actions">
        <a href="/contacto/" class="hero__cta">Hablar con un experto</a>
      </div>
    </div>
  </header>

  <main>
    <section class="service-finder reveal" aria-label="Necesidades principales">
      <div class="container">
        <span class="service-finder__label">Qué necesita</span>
        <div class="service-finder__grid">
          <a href="/territorios/" class="service-finder__item">
            <small>01</small>
            <span>Comprar o vender territorio de alto valor ecológico</span>
          </a>
          <a href="/servicios/" class="service-finder__item">
            <small>02</small>
            <span>Restaurar y gestionar</span>
          </a>
          <a href="/vision/" class="service-finder__item">
            <small>03</small>
            <span>Conocer su valor ecológico</span>
          </a>
          <a href="/clientes/" class="service-finder__item">
            <small>04</small>
            <span>Invertir en capital natural</span>
          </a>
        </div>
      </div>
    </section>

    <section class="manifesto-section reveal">
      <div class="manifesto-section__image">
        <img src="/imagenes/territorio-legado.jpg" alt="Paisaje natural gestionado por Territorium">
      </div>
      <div class="manifesto-section__copy">
        <span class="section-kicker">Somos de la tierra</span>
        <h2>Nacemos, vivimos y volvemos a ella.</h2>
        <p>
          Desde la tierra nacen nuestros alimentos, nuestra historia y las vidas
          que viven en ella. En Territorium medimos y activamos ese valor para
          que el legado también sea rentable y resiliente.
        </p>
      </div>
    </section>

    <section class="home-chapters reveal">
      <div class="container">
        <div class="chapter-grid">
          <a href="/servicios/" class="chapter-card">
            <span>Servicios</span>
            <h3>Qué hacemos</h3>
            <p>Diagnóstico, gestión, capital natural y restauración llave en mano.</p>
          </a>
          <a href="/territorios/" class="chapter-card">
            <span>Territorios</span>
            <h3>Comprar, restaurar, vender</h3>
            <p>Operaciones sobre territorios de alto valor ecológico.</p>
          </a>
          <a href="/vision/" class="chapter-card">
            <span>Visión</span>
            <h3>Valor ecológico medible</h3>
            <p>Biodiversidad, resiliencia climática y tesis de inversión.</p>
          </a>
          <a href="/por-que-nosotros/" class="chapter-card">
            <span>Por qué nosotros</span>
            <h3>No solo intermediamos</h3>
            <p>Medimos, estructuramos, restauramos y activamos valor natural.</p>
          </a>
          <a href="/clientes/" class="chapter-card">
            <span>Para quién</span>
            <h3>Propietarios, inversores y empresas</h3>
            <p>Una entrada diferente para cada tipo de decisión.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const slides = [
    {
      image: "/imagenes/fondo-1.webp",
      title: "Territorios con valor natural<br/>para inversores y propietarios",
      subtitle: "Asesoramiento en compraventa, valoración y activación de activos rústicos."
    },
    {
      image: "/imagenes/fondo-2.webp",
      title: "Restauración ecológica<br/>llave en mano",
      subtitle: "Diseño, ejecución, seguimiento e informes para transformar territorio con rigor."
    },
    {
      image: "/imagenes/fondo-3.webp",
      title: "Capital natural<br/>convertido en estrategia patrimonial",
      subtitle: "Integramos ciencia, datos y criterio financiero para multiplicar el valor territorial."
    }
  ];

  let currentIndex = 0;
  let carouselTimer: number | undefined;
  const heroElement = document.getElementById('hero-carousel') as HTMLElement;
  const titleElement = document.getElementById('carousel-title') as HTMLElement;
  const subtitleElement = document.getElementById('carousel-subtitle') as HTMLElement;

  const heroGradient = "linear-gradient(90deg, rgba(10,20,32,0.82), rgba(10,20,32,0.48) 48%, rgba(10,20,32,0.18))";
  const imageCache = new Map<string, Promise<void>>();

  function preloadHeroImage(src: string) {
    if (imageCache.has(src)) return imageCache.get(src);

    const promise = new Promise<void>((resolve) => {
      const image = new Image();
      image.onload = () => resolve();
      image.onerror = () => resolve();
      image.src = src;
    });

    imageCache.set(src, promise);
    return promise;
  }

  function changeSlide() {
    currentIndex = (currentIndex + 1) % slides.length;
    const next = slides[currentIndex];

    if (titleElement && subtitleElement && heroElement) {
      titleElement.classList.remove('fade-in');
      subtitleElement.classList.remove('fade-in');
      titleElement.classList.add('fade-out');
      subtitleElement.classList.add('fade-out');

      setTimeout(() => {
        heroElement.style.backgroundImage =
          `${heroGradient}, url('${next.image}')`;
        titleElement.innerHTML = next.title;
        subtitleElement.textContent = next.subtitle;
        titleElement.classList.remove('fade-out');
        subtitleElement.classList.remove('fade-out');
        titleElement.classList.add('fade-in');
        subtitleElement.classList.add('fade-in');
      }, 600);
    }
  }

  Promise.all(slides.map((slide) => preloadHeroImage(slide.image))).then(() => {
    if (!carouselTimer) {
      carouselTimer = window.setInterval(changeSlide, 6000);
    }
  });

  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries, currentObserver) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
          currentObserver.unobserve(entry.target);
        }
      });
    }, { root: null, rootMargin: "0px", threshold: 0.1 });

    document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
  });
</script>
