---
import Layout from '../../layouts/Layout.astro';
---

<Layout lang="en" title="Thank you - Territorium Capital">
  <main class="thanks-page">
    <section class="thanks-card">
      <span class="section-kicker">Enquiry received</span>
      <h1>Thank you. We have received your message.</h1>
      <p>
        We will review the information and reply as soon as possible from
        blanca@territorium.capital.
      </p>
      <a href="/en/">Back to home</a>
    </section>
  </main>
</Layout>

<style>
  .thanks-page {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding: var(--space-16) var(--space-6);
  }

  .thanks-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: 0 24px 70px rgba(24, 43, 73, 0.12);
    max-width: 44rem;
    padding: clamp(var(--space-8), 6vw, var(--space-16));
  }

  .thanks-card h1 {
    color: var(--color-indigo);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 400;
    line-height: 1.08;
  }

  .thanks-card p {
    color: var(--color-body);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-top: var(--space-6);
  }

  .thanks-card a {
    border-bottom: 2px solid var(--color-indigo);
    color: var(--color-indigo);
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-top: var(--space-8);
    padding-bottom: var(--space-1);
    text-transform: uppercase;
  }
</style>
