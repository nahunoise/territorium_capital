---
// src/layouts/Layout.astro
export interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
  canonicalPath?: string;
  showContactForm?: boolean;
  preloadImages?: string[];
}

const {
  title = "Territorium - Resiliencia y rentabilidad territorial",
  description = "Territorium asesora en compraventa de territorios, capital natural y restauración llave en mano para convertir suelo en resiliencia, rentabilidad y legado.",
  lang = 'es',
  canonicalPath,
  showContactForm = false,
  preloadImages = [],
} = Astro.props;

const isEn = lang === 'en';
const canonicalUrl = `https://territorium.capital${canonicalPath ?? (isEn ? '/en/' : '/')}`;
const nav = isEn
  ? {
      home: 'Home',
      services: 'Services',
      territories: 'Territories',
      insight: 'Insight',
      audience: 'Who we serve',
      contact: 'Contact',
    }
  : {
      home: 'Inicio',
      services: 'Servicios',
      territories: 'Territorios',
      insight: 'Visión',
      audience: 'Para quién',
      contact: 'Contacto',
    };

const navLinks = isEn
  ? {
      home: '/en/',
      services: '/en/#servicios',
      territories: '/en/#territorios',
      insight: '/en/#vision',
      audience: '/en/#clientes',
      contact: '/en/#contacto',
    }
  : {
      home: '/',
      services: '/servicios/',
      territories: '/territorios/',
      insight: '/vision/',
      audience: '/clientes/',
      contact: '/contacto/',
    };

const footer = isEn
  ? {
      kicker: 'A profitable legacy',
      heading: 'Let’s talk about your territory.',
      bodyOne: 'Tomorrow’s land is managed today. At Territorium, we show that economic return and ecological regeneration are not opposing paths, but the only route to the future.',
      bodyTwo: 'Discover the hidden value of your land and secure a legacy for the next generations.',
      contact: 'Contact',
      investors: 'Investors / partners',
      formTitle: 'Tell us about your territory',
      name: 'Name',
      email: 'Email',
      phone: 'Phone',
      interest: 'Type of enquiry',
      interestPlaceholder: 'Select an option',
      options: ['Buy or sell', 'Restore and manage', 'Ecological valuation', 'Natural capital investment'],
      message: 'Message',
      messagePlaceholder: 'Location, surface area, objective or any relevant context.',
      submit: 'Send enquiry',
    }
  : {
      kicker: 'Un legado rentable',
      heading: 'Hablemos de su territorio.',
      bodyOne: 'El suelo del mañana se gestiona hoy. En Territorium demostramos que la rentabilidad económica y la regeneración ecológica no son caminos opuestos, sino la única vía hacia el futuro.',
      bodyTwo: 'Descubra el valor oculto de su tierra y asegure un legado para las próximas generaciones.',
      contact: 'Contacto',
      investors: 'Inversores / socios',
      formTitle: 'Cuéntenos sobre su territorio',
      name: 'Nombre',
      email: 'Email',
      phone: 'Teléfono',
      interest: 'Tipo de consulta',
      interestPlaceholder: 'Seleccione una opción',
      options: ['Comprar o vender', 'Restaurar y gestionar', 'Valoración ecológica', 'Invertir en capital natural'],
      message: 'Mensaje',
      messagePlaceholder: 'Ubicación, superficie, objetivo o cualquier contexto relevante.',
      submit: 'Enviar consulta',
    };

const formNextUrl = isEn ? 'https://territorium.capital/en/thanks/' : 'https://territorium.capital/gracias/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href="https://territorium.capital/" />
    <link rel="alternate" hreflang="en" href="https://territorium.capital/en/" />
    <link rel="alternate" hreflang="x-default" href="https://territorium.capital/" />
    {preloadImages.map((imagePath) => (
      <link rel="preload" as="image" href={imagePath} />
    ))}
    <title>{title}</title>

  <!-- Tipografía principal: Alice -->
<!-- Tipografía para títulos: Alice -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Alice&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- NAVEGACIÓN GLOBAL -->
    <nav class="site-nav">
      <div class="nav-logo">
        <a href={navLinks.home}>
          <img class="nav-logo__image" src="/tcl.png" alt="Territorium Capital">
        </a>
      </div>

      <ul class="nav-list">
        <li><a href={navLinks.home} class="nav-link">{nav.home}</a></li>
        <li><a href={navLinks.services} class="nav-link">{nav.services}</a></li>
        <li><a href={navLinks.territories} class="nav-link">{nav.territories}</a></li>
        <li><a href={navLinks.insight} class="nav-link">{nav.insight}</a></li>
        <li><a href={navLinks.audience} class="nav-link">{nav.audience}</a></li>
        <li><a href={navLinks.contact} class="nav-link nav-link--muted">{nav.contact}</a></li>
      </ul>

      <div class="language-switch" aria-label={isEn ? 'Language selector' : 'Selector de idioma'}>
        <a href="/" class:list={['language-switch__link', !isEn && 'language-switch__link--active']}>ES</a>
        <span aria-hidden="true">|</span>
        <a href="/en/" class:list={['language-switch__link', isEn && 'language-switch__link--active']}>EN</a>
      </div>
    </nav>

    <!-- CONTENIDO DE LA PÁGINA -->
    <slot />

    <!-- PIE DE PÁGINA GLOBAL -->
    <footer id="contacto" class="site-footer">
      <div class="footer-block footer-block--brand">
        <span class="footer-kicker">{footer.kicker}</span>
        <h2 class="footer-heading">{footer.heading}</h2>
        <p class="footer-body">{footer.bodyOne}</p>
        <p class="footer-body">{footer.bodyTwo}</p>
      </div>

      <div class="footer-block footer-block--contact">
        <div class="contact-info">
          <span class="contact-label">{footer.contact}</span>
          <a href="mailto:blanca@territorium.capital" class="contact-link contact-link--email">
            blanca@territorium.capital
          </a>
        </div>

        <div class="contact-info">
          <span class="contact-label">WhatsApp</span>
          <a href="https://wa.me/34646051005" target="_blank" rel="noopener noreferrer" class="contact-link">
            +34 646 051 005
          </a>
        </div>

        <div class="contact-info">
          <span class="contact-label">{footer.investors}</span>
        </div>

        {showContactForm && (
        <form class="contact-form" action="https://formsubmit.co/blanca@territorium.capital" method="POST">
          <input type="hidden" name="_subject" value="Nueva consulta desde Territorium Capital" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={formNextUrl} />
          <input type="text" name="_honey" class="contact-form__honey" tabindex="-1" autocomplete="off" />

          <h3>{footer.formTitle}</h3>

          <label>
            <span>{footer.name}</span>
            <input type="text" name="Nombre" autocomplete="name" required />
          </label>

          <label>
            <span>{footer.email}</span>
            <input type="email" name="Email" autocomplete="email" required />
          </label>

          <label>
            <span>{footer.phone}</span>
            <input type="tel" name="Teléfono" autocomplete="tel" />
          </label>

          <label>
            <span>{footer.interest}</span>
            <select name="Tipo de consulta" required>
              <option value="">{footer.interestPlaceholder}</option>
              {footer.options.map((option) => <option value={option}>{option}</option>)}
            </select>
          </label>

          <label>
            <span>{footer.message}</span>
            <textarea name="Mensaje" rows="5" placeholder={footer.messagePlaceholder} required></textarea>
          </label>

          <button type="submit">{footer.submit}</button>
        </form>
        )}
      </div>
    </footer>
  </body>
</html>

<style is:global>
  
  /* ─── DESIGN TOKENS ─────────────────────────────────────── */
  :root {
    /* Paleta */
    --color-sand:       #F4F1EA;   /* fondo base */
    --color-sand-dark:  #D8D0C2;   /* elementos secundarios sobre arena */
    --color-indigo:     #182B49;   /* acento principal / textos de marca */
    --color-indigo-mid: #233E63;   /* sección ejes de trabajo */
    --color-body:       #4B5563;   /* cuerpo de texto */
    --color-white:      #FFFFFF;
    --color-gold:       #9B7B4F;
    --color-border:     rgba(24, 43, 73, 0.16);

    /* Tipografía */
    --font-base: 'Plus Jakarta Sans', sans-serif;

    /* Escala tipográfica */
    --text-xs:  0.75rem;   /* 12px */
    --text-sm:  0.875rem;  /* 14px */
    --text-base: 1rem;     /* 16px */
    --text-lg:  1.125rem;  /* 18px */
    --text-xl:  1.25rem;   /* 20px */
    --text-2xl: 1.5rem;    /* 24px */
    --text-3xl: 1.875rem;  /* 30px */
    --text-4xl: 2.25rem;   /* 36px */
    --text-5xl: 3rem;      /* 48px */

    /* Espaciado base */
    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;
    --space-24: 6rem;

    /* Radios */
    --radius-sm:  0.25rem;
    --radius-md:  0.5rem;
    --radius-xl:  0.75rem;
    --radius-2xl: 1rem;
    --radius-top: 2rem;     /* para la sección azul con bordes superiores redondeados */

    /* Contenedor */
    --container-max: 64rem;   /* ~1024px */
    --container-narrow: 48rem; /* ~768px */
  }

  /* ─── RESET MÍNIMO ───────────────────────────────────────── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  /* ─── BASE ───────────────────────────────────────────────── */
  body {
    font-family: var(--font-base);
    background-color: var(--color-sand);
    color: var(--color-indigo);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img, video {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  /* ─── NAVEGACIÓN ─────────────────────────────────────────── */
  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-8);
    width: 100%;
    max-width: none;
    margin-inline: 0;
    min-height: 82px;
    padding: 0.85rem var(--space-8);
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 12px 30px rgba(24, 43, 73, 0.05);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .nav-logo {
    flex: 0 0 auto;
  }

  .nav-logo img.nav-logo__image {
    height: 54px;
    width: auto;
    display: block;
  }

  .nav-list {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-6);
    margin-left: auto;
  }

  .language-switch {
    align-items: center;
    border-left: 1px solid var(--color-border);
    display: flex;
    gap: 0.45rem;
    padding-left: var(--space-4);
    white-space: nowrap;
  }

  .language-switch__link {
    color: rgba(24, 43, 73, 0.55);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .language-switch__link:hover,
  .language-switch__link--active {
    color: var(--color-indigo);
  }

  .nav-link {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-indigo);
    text-transform: uppercase;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-gold);
    text-decoration: none;
  }

  .nav-link--muted {
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .site-nav {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "logo lang"
        "nav nav";
      gap: var(--space-3);
      min-height: auto;
      padding-inline: var(--space-4);
    }

    .nav-logo {
      grid-area: logo;
    }

    .nav-logo img.nav-logo__image {
      height: 40px;
    }

    .nav-list {
      grid-area: nav;
      justify-content: flex-start;
      gap: var(--space-4);
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: var(--space-1);
      scrollbar-width: none;
      width: 100%;
    }

    .nav-list::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      font-size: 0.68rem;
      white-space: nowrap;
    }

    .language-switch {
      grid-area: lang;
      justify-self: end;
      border-left: 0;
      padding-left: 0;
    }
  }

  /* ─── HERO ───────────────────────────────────────────────── */

  /* Títulos elegantes con Alice */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Alice', serif;
}

/* Cuerpo de texto con Avenir (y sus alternativas) */
body {
  font-family: 'Avenir', 'Avenir Next', 'Montserrat', 'Segoe UI', sans-serif;
}
  .hero {
    position: relative;
    height: 620px;
    background-color: #2d3748;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding: var(--space-6) clamp(var(--space-6), 5vw, var(--space-20));
  }

  .hero__content {
    max-width: 46rem;
    color: var(--color-white);
  }

  .hero__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.86;
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-size: clamp(2.7rem, 5.6vw, 5.6rem);
    font-weight: 400;
    line-height: 0.98;
    margin-bottom: var(--space-6);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    opacity: 0.9;
    max-width: 40rem;
    margin-bottom: var(--space-8);
  }

  .hero__cta {
    display: inline-block;
    border-bottom: 2px solid var(--color-white);
    padding-bottom: var(--space-1);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }

  .hero__cta:hover {
    opacity: 0.8;
  }

  /* ─── CONTENEDOR GENÉRICO ────────────────────────────────── */
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .container--narrow {
    max-width: var(--container-narrow);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  /* ─── SECCIÓN INTRO / PROPÓSITO ─────────────────────────── */
  .section-intro {
    padding-block: var(--space-20);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .section-intro__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-intro__heading {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    font-weight: 700;
    max-width: 36rem;
    margin-inline: auto;
    line-height: 1.3;
	color: var(--color-indigo);
  }

  .section-intro__body {
    font-size: var(--text-sm);
    color: var(--color-body);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.75;
  }

  .section-intro__quote {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--color-body);
    max-width: 32rem;
    margin-inline: auto;
    line-height: 1.75;
    padding-top: var(--space-6);
  }

  /* ─── SECCIÓN EJES DE TRABAJO (fondo azul) ───────────────── */
  .section-axes {
    background: linear-gradient(180deg, var(--color-indigo) 0%, var(--color-indigo-mid) 100%);
    color: var(--color-white);
    padding-block: var(--space-20);
    padding-inline: var(--space-6);
    border-radius: 0;
  }

  .section-axes__label {
    text-align: center;
    font-weight: 700;
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-12);
  }

  .axes-showcase {
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
    gap: var(--space-10, 2.5rem);
    align-items: stretch;
  }

  .axes-feature {
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-left: 4px solid var(--color-gold);
    padding: clamp(var(--space-8), 4vw, var(--space-12));
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.18);
  }

  .axes-feature__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .axes-feature h3 {
    font-family: 'Alice', serif;
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 400;
    line-height: 1.04;
    margin-block: var(--space-5);
    color: var(--color-white);
  }

  .axes-feature p {
    color: rgba(255, 255, 255, 0.78);
    font-size: var(--text-base);
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  .axes-feature__cta {
    width: fit-content;
    border: 1px solid rgba(255, 255, 255, 0.42);
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .axes-feature__cta:hover {
    background: var(--color-white);
    border-color: var(--color-white);
    color: var(--color-indigo);
  }

  .axes-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    border: 0;
  }

  .card-axis {
    color: var(--color-white);
    padding: var(--space-6);
    border: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    min-height: 188px;
    background: rgba(255, 255, 255, 0.055);
  }

  .card-axis__number {
    color: var(--color-gold);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .card-axis__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-axis__name {
    font-family: 'Alice', serif;
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--color-white);
    margin: 0;
  }

  .card-axis__tag {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.82);
  }

  .card-axis__body {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.68);
  }

  .transaction-flow {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .transaction-flow article {
    background: rgba(255, 255, 255, 0.62);
    border-top: 2px solid rgba(24, 43, 73, 0.32);
    min-height: 210px;
    padding: var(--space-6);
  }

  .transaction-flow span {
    color: var(--color-gold);
    display: block;
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-5, 1.25rem);
  }

  .transaction-flow h3 {
    color: var(--color-indigo);
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-3);
  }

  .transaction-flow p {
    color: var(--color-body);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .restoration-cinema.container {
    max-width: 78rem;
  }

  .restoration-compare__caption {
    background: rgba(24, 43, 73, 0.74);
    backdrop-filter: blur(10px);
    bottom: var(--space-6);
    color: var(--color-white);
    display: grid;
    gap: var(--space-1);
    left: var(--space-6);
    max-width: min(28rem, calc(100% - 3rem));
    padding: var(--space-5, 1.25rem);
    position: absolute;
    z-index: 6;
  }

  .restoration-compare__caption strong {
    font-family: 'Alice', serif;
    font-size: var(--text-2xl);
    font-weight: 400;
  }

  .restoration-compare__caption span {
    color: rgba(255, 255, 255, 0.76);
    font-size: var(--text-sm);
  }

  .science-method {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .science-method span {
    background: #f7f4ee;
    border: 1px solid var(--color-border);
    color: var(--color-indigo);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.65rem 0.8rem;
    text-transform: uppercase;
  }

  /* ─── PIE DE PÁGINA ──────────────────────────────────────── */
  .site-footer {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-20) var(--space-6) var(--space-24);
    text-align: left;
    display: grid;
